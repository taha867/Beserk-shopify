        "question_7qpfya": {
          "type": "question",
          "name": "Christmas Delivery Cut Offs?",
          "disabled": true,
          "settings": {
            "question": "Christmas Delivery Cut Offs?",
            "answer": "<p>Our 2025 Christmas Cut Offs are:<br/><strong><br/>AUSTRALIA<br/></strong><em><strong>Standard Post:</strong></em><em><br/></em><strong>NT: </strong>12 December<br/><strong>WA:</strong> 17 December<br/><strong>TAS: </strong>18 December<strong><br/>NSW, ACT, VIC, SA:</strong> 19 December<br/><strong>QLD: </strong>22 December</p><p><em><strong>Express Post:</strong></em><strong><br/>NT, WA, TAS:</strong> 22 December<strong><br/>QLD, NSW, ACT, VIC, SA:</strong> 23 December<br/><br/><strong>NEW ZEALAND<br/></strong><em><strong>Standard Post: </strong></em>11 December<br/><em><strong>Express Post: </strong></em>15 December<br/><br/>For other countries please refer to our <a href=\"/pages/beserk-postage-delivery\" target=\"_blank\" title=\"Postage & Delivery\">Postage & Delivery Page. </a></p><p>For further inquiries please visit the Australia Post website or <a href=\"/pages/contact-us\" target=\"_blank\" title=\"Contact Us\">contact us!</a><br/><strong><br/></strong></p>"
          }
        },
        "question_YLYgA7": {
          "type": "question",
          "name": "Do you ship overseas?",
          "settings": {
            "question": "Do you ship overseas?",
            "answer": "<p>Yes, we ship all over the world. Shipping costs will apply, and will be added at checkout.</p><p><strong>To see more information head to our Postage + Delivery page </strong><a href=\"/pages/beserk-postage-delivery\" title=\"Postage & Delivery\"><strong>HERE</strong></a><strong>!</strong></p>"
          }
        },
        "question_HNHdbx": {
          "type": "question",
          "name": "How much is postage?",
          "settings": {
            "question": "How much is postage?",
            "answer": "<p><strong>If you're in Australia</strong><br/><br/>We offer FREE shipping for all orders over $129AUD or flat rate shipping of $11.95 AUD for orders under $129AUD.</p><p>Express shipping starts at $12.95AUD and goes up depending on the size of the parcel!</p><p><strong>If you're in New Zealand</strong><br/><br/>We offer FREE shipping for all orders over $229AUD or flat rate shipping of $19.95AUD for orders under $229AUD.</p><p>Express Shipping starts at $29.95AUD.</p><p><strong>Rest of the World</strong><br/><br/>Regular shipping starts at $16.95AUD and express shipping starts at $26.95AUD.<br/><br/><strong>PLEASE NOTE:</strong> Costs will vary depending the weight of the parcel.</p><p><strong>To see more information head to our Postage + Delivery page </strong><a href=\"/pages/beserk-postage-delivery\" title=\"Postage & Delivery\"><strong>HERE</strong></a><strong>!</strong></p>"
          }
        },
        "question_QENgDx": {
          "type": "question",
          "name": "How long will it take to get my orders?",
          "settings": {
            "question": "How long will it take to get my orders?",
            "answer": "<p>It depends on where you are. Orders processed here will take 5 - 7 business days to arrive. Overseas deliveries can take anywhere from 7 - 16 days. Delivery details will be provided in your confirmation email.</p>"
          }
        },
        "question_GNHCFb": {
          "type": "question",
          "name": "Do you offer same-day or express delivery?",
          "settings": {
            "question": "Do you offer same-day or express delivery?",
            "answer": "<p>We aren't able to offer same day delivery however we do offer Express through Australia Post! All orders placed before 2pm are sent out the same day.</p><p><strong>Alternatively, we offer Click & Collect</strong> from our warehouse in Virginia during our opening hours - 8:30am to 4:30pm Monday to Friday</p><p>If you have a deadline, we always recommend selecting Express Post or Click & Collect to give your order the best chance of reaching you on time!  </p><p><strong>Still have questions?</strong> Send a live chat to our team, we're always happy to help!</p>"
          }
        },
        "question_fVJGVN": {
          "type": "question",
          "name": "Do you offer same day dispatch?",
          "settings": {
            "question": "Do you offer same day dispatch?",
            "answer": "<p>Yes! Place (and pay for) an order before 2pm AEST and it will be sent out same day 😊</p><p><strong>Please note: </strong>In busy periods such as sales, we may not be able to offer our usual same day shipping.</p>"
          }
        },
        "question_dGYFDy": {
          "type": "question",
          "name": "Can I pick up my order?",
          "settings": {
            "question": "Can I pick up my order?",
            "answer": "<p><strong>Yes! </strong>We offer Click & Collect from our warehouse in Virginia. </p><p>Simply select 'Pick up' at checkout and the team will aim to have your order ready within an hour! </p><p>You're welcome to collect your order anytime during our opening hours - 8:30am to 4:30pm Monday to Friday :)<br/><br/><strong>Have more questions? </strong>Send a live chat to our helpful team!</p>"
          }
        },
