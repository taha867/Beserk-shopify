    "rewards_content_wyTKCQ": {
      "type": "rewards-content",
      "blocks": {
        "text_content_VpixBT": {
          "type": "text-content",
          "settings": {
            "heading": "<h3>BESERK REWARDS</h3>",
            "text_content": "<ul><li>RECEIVE $5 OFF YOUR FIRST ORDER - 100 BONUS Beserk Points</li><li>Earn 1 Point for every $1 Spent</li><li>Earn Points for Social Media sharing</li><li>Receive a Bonus 20 Points on your Birthday!</li><li>Receive 10 Points for All Reviews</li><li>Sign up for the Beserk Newsletter to receive 5 Bonus Points</li></ul><p></p><h2><br/></h2><h2><strong>SPEND YOUR POINTS & RECEIVE $ OFF YOUR NEXT ORDER</strong></h2><p></p><p>After you have enough points you can then REDEEM your points for a voucher to use against $$ OFF your next order. Simply click 'Spend my Points' above & select your voucher.<br/><br/></p><ul><li>?? Reward Points =<strong>FREE PRODUCTS</strong><em><strong>(Items Change Regularly!)</strong></em></li><li>50 Reward Points =<strong>$2.50 OFF VOUCHER </strong></li><li><strong>1</strong>00 Reward Points =<strong>$5 OFF VOUCHER </strong></li><li>200 Reward Points =<strong>$10 OFF VOUCHER</strong></li></ul><p><strong><br/><br/></strong></p><h2><strong>Please Note: </strong></h2><ul><li>Points never expire just as long as you make 1 transaction per year. Your points will expire 365 days after they were awarded if you do not make a transaction during that time. If you do place an order then your points are refreshed and valid for another 365 days. </li><li>Points are not redeemable for cash. </li><li>Only 1 voucher can be used per order. </li><li>Minimum order value $49. </li><li>Reward points cannot be used to purchase Gift Cards.</li><li>200 Reward Points =<strong>$10 OFF VOUCHER</strong></li></ul><p><strong><br/></strong></p>"
          }
        },
        "text_content_8waX9L": {
          "type": "text-content",
          "settings": {
            "heading": "",
            "text_content": "<p></p><p>Points will be automatically added to your reward balance after your order or action is complete. Please note: Your birthdate must be added at least 1 month BEFORE your Birthday to receive the Birthday bonus points. Limits on points earned for Social media sharing apply.</p>"
          }
        },
