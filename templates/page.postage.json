        },
        "richtext_yWCkjC": {
          "type": "richtext",
          "settings": {
            "content": "<p><em><strong>During sale periods, we cannot guarantee same day dispatch. Orders will be shipped ASAP</strong></em></p><p><strong>Please Note: </strong>We do not sell cheap copies. All items on the Beserk website are 100% genuine, officially licensed products. We are not a drop-shipping company, our items are held at our warehouse in Virginia, QLD Australia.</p>"
          }
        },
        "heading_qdVQRJ": {
          "type": "heading",
          "name": "CLICK & COLLECT",
          "settings": {
            "text": "<strong>♥ CLICK & COLLECT ♥</strong>",
            "heading_tag": "h1"
          }
        },
        "richtext_xR8PQf": {
          "type": "richtext",
          "settings": {
            "content": "<p>Orders will be ready within one hour. Please make sure to collect during our business hours : <br/><strong>8.30am to 4.30pm - Mon-Fri -</strong> <strong>Beserk Warehouse - 2/58 Yarraman Place,<br/>Virginia, QLD 4014 Australia<br/></strong></p><p>Please note this address is for ORDER COLLECTION Only. We do not have a retail outlet.<br/><br/><br/></p>"
          }
        },
        "heading_Ji8Rbb": {
          "type": "heading",
          "name": "TRACKING",
          "settings": {
            "text": "<strong>♥ FULL TRACKING & ORDER GUARANTEE ♥</strong>",
            "heading_tag": "h1"
          }
        },
        "richtext_R8tdQ7": {
          "type": "richtext",
          "settings": {
            "content": "<p><strong>All orders include full tracking </strong>so you can monitor your delivery at any time. Delivery includes Full Tracking, Signature on Delivery option & Order Guarantee. </p><p>For added protection, choose <strong>Signature on Delivery</strong>— this way if your parcel is stolen, we’ll replace it at no charge. We are unable to provide credits, refunds or replacements for stolen parcels where \"Signature on Delivery\" is not selected.</p><p>Orders are collected daily at 11am & 2pm. You'll receive a tracking email between 3–4pm once your order is processed.<br/><br/>To help ensure fast delivery, add any special instructions in the comments at checkout. You can track your parcel via the link in the email or by entering the tracking number on the Australia Post website <a href=\"http://auspost.com.au/track/track.html\" target=\"_blank\" title=\"http://auspost.com.au/track/track.html\">HERE</a></p>"
          }
        }
