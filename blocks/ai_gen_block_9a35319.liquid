{% doc %}
  @prompt
    add in a section where I can upload a big clearance header and then big  text under saying CLEARANCE SALE ON NOW , black background white text

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-clearance-banner-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    text-align: center;
    width: 100%;}

  .ai-clearance-banner__image-container-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.image_bottom_spacing }}px;
    max-width: 100%;
  }

  .ai-clearance-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    max-width: {{ block.settings.max_image_width }}px;
    margin: 0 auto;
    display: block;
  }

  .ai-clearance-banner__image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    border: 2px dashed #cccccc;
    border-radius: 8px;
    padding: 40px 20px;
    margin: 0 auto;
    max-width: {{ block.settings.max_image_width }}px;
    position: relative;
  }

  .ai-clearance-banner__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    max-height: 200px;
    opacity: 0.5;
  }

  .ai-clearance-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    background: rgba(255, 255, 255, 0.9);
    padding: 8px 12px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .ai-clearance-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    text-transform: {{ block.settings.text_transform }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin: 0;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-clearance-banner-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-clearance-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.8 }}px;
    }

    .ai-clearance-banner__image-container-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.image_bottom_spacing | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-clearance-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-clearance-banner__image-container-{{ ai_gen_id }}">
    {% if block.settings.clearance_image %}
      <img
        src="{{ block.settings.clearance_image | image_url: width: 2000 }}"
        alt="{{ block.settings.clearance_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.clearance_image.width }}"
        height="{{ block.settings.clearance_image.height }}"
        class="ai-clearance-banner__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-clearance-banner__image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-clearance-banner__empty-state-{{ ai_gen_id }}">
          Upload your clearance header image
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.banner_text != blank %}
    <h2 class="ai-clearance-banner__text-{{ ai_gen_id }}">
      {{ block.settings.banner_text }}
    </h2>
  {% endif %}
</div>

{% schema %}
{
  "name": "Clearance banner",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "clearance_image",
      "label": "Clearance header image"
    },
    {
      "type": "range",
      "id": "max_image_width",
      "min": 200,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum image width",
      "default": 800
    },
    {
      "type": "range",
      "id": "image_bottom_spacing",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Space below image",
      "default": 30
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text",
      "default": "CLEARANCE SALE ON NOW"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Text size",
      "default": 48
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "900",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min":0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Letter spacing",
      "default": 2
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Clearance banner"
    }
  ],
  "tag": null
}
{% endschema %}