{% if customer %}
  <section class="customer-profile">
    <div class="profile-view" id="profile-view">
      <h2>My Profile</h2>
      <p><strong>First Name:</strong> {{ customer.first_name }}</p>
      <p><strong>Last Name:</strong> {{ customer.last_name }}</p>
      <p><strong>Email:</strong> {{ customer.email }}</p>
      <p><strong>Phone:</strong> {{ customer.phone | default: 'Not Provided' }}</p>
      <button type="button" id="edit-profile-btn" class="edit-btn">Edit</button>
    </div>

    <div class="profile-edit cp-hidden" id="profile-edit">
      <h2>Edit Profile</h2>
      {% form 'customer' %}
        {% if form.posted_successfully? %}
          <p class="success-msg">✅ Your profile has been updated.</p>
        {% endif %}

        {% if form.errors %}
          <p class="error-msg">{{ form.errors | default_errors }}</p>
        {% endif %}

        <div class="form-field">
          <label for="FirstName">First Name</label>
          <input type="text" id="FirstName" name="customer[first_name]" value="{{ customer.first_name }}" required minlength="2" maxlength="50" pattern=".*\S.*" title="Please enter your first name">
        </div>

        <div class="form-field">
          <label for="LastName">Last Name</label>
          <input type="text" id="LastName" name="customer[last_name]" value="{{ customer.last_name }}" required minlength="2" maxlength="50" pattern=".*\S.*" title="Please enter your last name">
        </div>

        <div class="form-field">
          <label for="Email">Email</label>
          <input type="email" id="Email" name="customer[email]" value="{{ customer.email }}" required maxlength="254">
        </div>

        <div class="form-field">
          <label for="Phone">Phone</label>
          <input type="tel" id="Phone" name="customer[phone]" value="{{ customer.phone }}">
        </div>

        <div class="form-actions">
          <button type="submit" class="update-btn">Save Changes</button>
          <button type="button" id="cancel-edit-btn" class="cancel-btn">Cancel</button>
        </div>
      {% endform %}
    </div>
  </section>
{% endif %}

<style>
  .customer-profile {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .customer-profile h2 {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }
  .customer-profile p {
    margin: 0.5rem 0;
    font-size: 0.95rem;
  }
  .cp-hidden { display: none; }
  .profile-edit .form-field {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }
  .profile-edit label {
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .profile-edit input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #d0d0d0;
    font-size: 0.95rem;
    background: #fff;
  }
  .profile-edit input:focus {
    outline: none;
    border-color: #1c1c1c;
  }
  .profile-edit .form-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }
  .update-btn {
    background: #e32c2b;
    color: #fff;
    border: none;
    padding: 10px 24px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .update-btn:hover { background: #c62424; }
  .cancel-btn {
    background: transparent;
    color: #1c1c1c;
    border: 1px solid #1c1c1c;
    padding: 10px 24px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .cancel-btn:hover { background: #f5f5f5; }
  .edit-btn {
    margin-top: 1rem;
    background: transparent;
    color: #1c1c1c;
    border: 1px solid #1c1c1c;
    padding: 8px 20px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .edit-btn:hover { background: #f5f5f5; }
  .success-msg {
    margin-bottom: 1rem;
    color: #2a7a2a;
    font-size: 0.9rem;
  }
  .error-msg {
    margin-bottom: 1rem;
    color: #e32c2b;
    font-size: 0.9rem;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const editBtn = document.getElementById('edit-profile-btn');
    const cancelBtn = document.getElementById('cancel-edit-btn');
    const viewBlock = document.getElementById('profile-view');
    const editBlock = document.getElementById('profile-edit');
    const profileForm = editBlock ? editBlock.querySelector('form') : null;
    const firstNameInput = document.getElementById('FirstName');
    const lastNameInput = document.getElementById('LastName');
    const emailInput = document.getElementById('Email');
    const phoneInput = document.getElementById('Phone');

    {% if form.errors %}
      if (viewBlock && editBlock) {
        viewBlock.classList.add('cp-hidden');
        editBlock.classList.remove('cp-hidden');
      }
    {% endif %}

    if (editBtn) {
      editBtn.addEventListener('click', function () {
        viewBlock.classList.add('cp-hidden');
        editBlock.classList.remove('cp-hidden');
      });
    }

    if (cancelBtn) {
      cancelBtn.addEventListener('click', function () {
        editBlock.classList.add('cp-hidden');
        viewBlock.classList.remove('cp-hidden');
      });
    }

    [firstNameInput, lastNameInput].forEach(function (input) {
      if (!input) {
        return;
      }

      input.addEventListener('input', function () {
        input.setCustomValidity('');
      });
    });

    if (emailInput) {
      emailInput.addEventListener('input', function () {
        emailInput.setCustomValidity('');
      });
    }

    if (profileForm) {
      profileForm.addEventListener('submit', function (event) {
        if (firstNameInput) {
          firstNameInput.value = firstNameInput.value.trim();
          if (!firstNameInput.value) {
            firstNameInput.setCustomValidity('Please enter your first name.');
          }
        }

        if (lastNameInput) {
          lastNameInput.value = lastNameInput.value.trim();
          if (!lastNameInput.value) {
            lastNameInput.setCustomValidity('Please enter your last name.');
          }
        }

        if (emailInput) {
          emailInput.value = emailInput.value.trim();
        }

        if (phoneInput) {
          phoneInput.value = phoneInput.value.trim();
        }

        if (!profileForm.checkValidity()) {
          event.preventDefault();
          profileForm.reportValidity();
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Customer Profile",
  "settings": [],
  "presets": [
    {
      "name": "Customer Profile"
    }
  ]
}
{% endschema %}
