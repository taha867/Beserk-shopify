{% if customer %}
  <section class="customer-profile">
    <div class="profile-view" id="profile-view">
      <h2>My Profile</h2>
      <p><strong>First Name:</strong> {{ customer.first_name }}</p>
      <p><strong>Last Name:</strong> {{ customer.last_name }}</p>
      <p><strong>Email:</strong> {{ customer.email }}</p>
      <p><strong>Phone:</strong> {{ customer.phone | default: 'Not Provided' }}</p>
      <button type="button" id="edit-profile-btn" class="button edit-btn">Edit</button>
    </div>

    <div class="profile-edit cp-hidden" id="profile-edit">
      <h2>Edit Profile</h2>
      {% form 'customer' %}
        {% if form.posted_successfully? %}
          <p class="success-msg">✅ Your profile has been updated.</p>
        {% endif %}

        {% if form.errors %}
          <p class="error-msg">{{ form.errors | default_errors }}</p>
        {% endif %}

        <div class="form-field">
          <label for="FirstName">First Name</label>
          <input type="text" id="FirstName" name="customer[first_name]" value="{{ customer.first_name }}" required>
        </div>

        <div class="form-field">
          <label for="LastName">Last Name</label>
          <input type="text" id="LastName" name="customer[last_name]" value="{{ customer.last_name }}" required>
        </div>

        <div class="form-field">
          <label for="Email">Email</label>
          <input type="email" id="Email" name="customer[email]" value="{{ customer.email }}" required>
        </div>

        <div class="form-field">
          <label for="Phone">Phone</label>
          <input type="tel" id="Phone" name="customer[phone]" value="{{ customer.phone }}">
        </div>

        <button type="submit" class="button update-btn">Save Changes</button>
        <button type="button" id="cancel-edit-btn" class="button cancel-btn">Cancel</button>
      {% endform %}
    </div>
  </section>
{% endif %}

<style>
  .customer-profile {
    max-width: 500px;
    margin: 20px auto;
    padding: 20px;
    border: 1px solid #eee;
    border-radius: 8px;
    background: #fafafa;
  }
  .customer-profile h2 { margin-bottom: 15px; }
  .customer-profile p { margin: 8px 0; }
  .cp-hidden { display: none; }
  .profile-edit .form-field { margin-bottom: 12px; display: flex; flex-direction: column; }
  .profile-edit input { padding: 8px; border: 1px solid #ccc; border-radius: 4px; }
  .profile-edit button { margin-top: 10px; padding: 10px 14px; border: none; border-radius: 4px; cursor: pointer; }
  .success-msg { margin-top: 12px; color: green; }
  .error-msg { margin-top: 12px; color: red; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const editBtn = document.getElementById('edit-profile-btn');
    const cancelBtn = document.getElementById('cancel-edit-btn');
    const viewBlock = document.getElementById('profile-view');
    const editBlock = document.getElementById('profile-edit');

    if (editBtn) {
      editBtn.addEventListener('click', function () {
        viewBlock.classList.add('cp-hidden');
        editBlock.classList.remove('cp-hidden');
      });
    }

    if (cancelBtn) {
      cancelBtn.addEventListener('click', function () {
        editBlock.classList.add('cp-hidden');
        viewBlock.classList.remove('cp-hidden');
      });
    }
  });
</script>

{% schema %}
{
  "name": "Customer Profile",
  "settings": [],
  "presets": [
    {
      "name": "Customer Profile"
    }
  ]
}
{% endschema %}
